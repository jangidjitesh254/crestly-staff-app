# Base URL of the Crestly API. Expo inlines EXPO_PUBLIC_* vars at build time.
#
# Simulator / emulator on the same machine: http://localhost:4000/api
# Android emulator (AVD):                   http://10.0.2.2:4000/api
# Physical device (Expo Go):                http://<your-LAN-IP>:4000/api
EXPO_PUBLIC_API_BASE_URL="http://localhost:4000/api"
